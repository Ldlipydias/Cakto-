rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users/{userId}/notifications
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required, immutable) - The ID of the user who generated the notification.
    //   - value: number (required) - The value of the PIX generated.
    //   - createdAt: timestamp (required, immutable) - When the notification was generated.
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    function uidUnchanged() {
      return !('userId' in request.resource.data) || request.resource.data.userId == request.auth.uid;
    }
    function uidNotModified() {
      return !('userId' in request.resource.data) || request.resource.data.userId == resource.data.userId;
    }
    
    // Domain Validators
    function isValidNotification(data) {
      return hasOnlyAllowedFields(['userId', 'value', 'createdAt']) &&
             data.userId is string && data.userId.size() > 0 && data.userId.size() < 100 &&
             data.value is number && data.value >= 0 &&
             data.createdAt is timestamp;
    }

    match /users/{userId}/notifications/{notificationId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidNotification(request.resource.data) && uidUnchanged();
      allow update: if isOwner(userId) && isValidNotification(request.resource.data) && uidNotModified() && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isOwner(userId);
    }
  }
}
